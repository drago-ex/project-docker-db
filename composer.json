{
	"name": "drago-ex/project-docker-db",
	"type": "drago-tools-resource",
	"description": "The package extends the Drago Project to include mysqli database on docker.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/database": "^3.0",
		"drago-ex/project-docker": "^2.0"
	},
	"extra": {
		"drago-tools": {
			"install": {
				"copy": {
					"resources/app": "app",
					"docker/Dockerfile-db": "docker",
					"docker-compose.override.yaml": "docker-compose.override.yaml"
				}
			}
		}
	},
	"require-dev": {
		"drago-ex/project-tools": "@dev"
	},
	"scripts": {
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
