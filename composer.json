{
	"name": "drago-ex/project-db",
	"type": "drago-project-resource",
	"description": "The package extends the Drago Project to include mysqli database.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/database": "^2.0",
		"drago-ex/project-docker": "^1.0"
	},
	"extra": {
		"drago-project": {
			"install": {
				"copy": {
					"resources/app": "app",
					"docker/Dockerfile-db": "docker",
					"docker-compose.override.yaml": "docker-compose.override.yaml"
				}
			}
		}
	},
	"scripts": {
		"post-install-cmd": [
			"php dev-copy.php"
		],
		"post-update-cmd": [
			"php dev-copy.php"
		]
	}
}
